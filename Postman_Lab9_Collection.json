{
  "info": {
    "_postman_id": "ecommerce-lab9",
    "name": "E-Commerce API - Lab 9 (Spring Security & Validation)",
    "description": "Complete Postman collection for testing E-Commerce REST API with Spring Security\n\nFeatures:\n- Session-based authentication (JSESSIONID)\n- User registration and login\n- Product CRUD operations with role-based access control\n- Input validation testing\n- Error handling demonstrations\n\nInstructions:\n1. Import this collection into Postman\n2. Enable \"Store cookies\" in Postman settings\n3. Enable \"Automatically follow redirects\"\n4. Run requests in order: Register → Login → Test protected endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
